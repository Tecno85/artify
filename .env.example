# Para despliegues administrados, descomenta y configura DATABASE_URL.
# DATABASE_URL=postgresql://usuario:contrasena@host:5432/artify_db?sslmode=require

# Para instalación local, usa las variables DB_*.
# Si un valor contiene espacios o #, escríbelo entre comillas dobles.
# Ejemplo: DB_PASSWORD="mi clave local#segura"
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_contrasena_postgresql
DB_NAME=artify_db

# Usa al menos 32 caracteres y reemplaza siempre este valor de ejemplo.
TOKEN_SECRET=cambia_este_valor_por_un_secreto_largo_y_aleatorio
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
